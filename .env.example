# Exemplo de variáveis de ambiente
# Copie este arquivo e renomeie para .env para desenvolvimento local
# Para produção, configure estas variáveis na Vercel

# Backend URL
VITE_BACKEND_URL=http://localhost:8000

# Stripe Configuration (use suas próprias chaves)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# App Configuration (opcional)
VITE_APP_NAME=Tickrify
VITE_APP_VERSION=1.0.0

# Development specific
NODE_ENV=development
